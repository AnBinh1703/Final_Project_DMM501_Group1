# Docker Compose environment overrides for local development
# Copy this to .env and edit as needed

# PostgreSQL host port (default 5432; use 5433 if port 5432 is already in use)
POSTGRES_PORT=5432

# API port (default 8000)
API_PORT=8000

# Frontend port (default 8082)
FRONTEND_PORT=8082

# MLflow port (default 5000)
MLFLOW_PORT=5000

# Prometheus port (default 9090)
PROMETHEUS_PORT=9090

# Grafana port (default 3000)
GRAFANA_PORT=3000
